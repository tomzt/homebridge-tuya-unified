{
  "displayName": "Homebridge Tuya Unified",
  "name": "homebridge-tuya-unified",
  "version": "0.1.0",
  "description": "Unified Homebridge plugin for Tuya smart home devices, merging homebridge-tuya-platform and tuya-homebridge into one actively maintained package with Cloud + Local hybrid control.",
  "license": "MIT",
  "author": "tomzt",
  "homepage": "https://github.com/tomzt/homebridge-tuya-unified#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomzt/homebridge-tuya-unified.git"
  },
  "bugs": {
    "url": "https://github.com/tomzt/homebridge-tuya-unified/issues"
  },
  "engines": {
    "node": "^18.20.4 || ^20.18.0 || ^22.10.0",
    "homebridge": ">=1.8.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "config.schema.json",
    "NOTICE"
  ],
  "keywords": [
    "homebridge-plugin",
    "tuya",
    "smart-home"
  ],
  "scripts": {
    "build": "rimraf ./dist && tsc",
