    "prepublishOnly": "npm run lint && npm run build",
    "test": "jest"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "pulsar-client": "^1.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "eslint": "^9.17.0",
    "homebridge": "^1.8.5",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
